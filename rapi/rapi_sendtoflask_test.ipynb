   "source": [
    "import cv2\n",
    "from ultralytics import YOLO\n",
    "\n",
    "frame =cv2.imread(\"dog.jpg\")\n",
    "model = YOLO(\"yolov8s.pt\")\n",
    "\n",
    "detect = model(frame)\n",
    "\n",
    "cv2.imshow(\"frame\",detect[0].plot())\n",
    "cv2.waitKey(0)\n",
    "\n",
    "cv2.destroyAllWindows()\n",
    "cv2.waitKey(1)"
   ]
